"""Test runner entry point for direct execution.

Usage:
  python /path/to/test-runner/run [test_directory]
  python /path/to/test-runner/run path/to/file_test.py
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))

from shell import main

if __name__ == "__main__":
    main()
